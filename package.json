{
  "name": "moura-patient-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Plataforma de relacionamento com pacientes da Moura Odontologia & Associados.",
  "scripts": {
    "dev": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build -w apps/api",
    "build:web": "npm run build -w apps/web",
    "lint": "npm run lint -w apps/api",
    "test": "npm run test -w apps/api",
    "prisma:generate": "npm run prisma:generate -w apps/api",
    "prisma:migrate": "npm run prisma:migrate -w apps/api"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
